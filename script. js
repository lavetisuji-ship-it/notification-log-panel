body{
  font-family: Arial;
  background:#f2f2f2;
  padding:20px;
}

.header{
  background:#222;
  color:white;
  text-align:center;
  padding:20px;
  border-radius:10px;
  font-size:28px;
  font-weight:bold;
}

input,textarea{
  width:100%;
  padding:12px;
  margin-top:10px;
  border-radius:8px;
}

.addBtn{
  background:green;
  color:white;
  border:none;
  padding:12px 20px;
  margin-top:10px;
  border-radius:8px;
}

.card{
  background:white;
  margin-top:15px;
  padding:15px;
  border-radius:10px;
  box-shadow:0 2px 5px gray;
}